{
  "manifest_version": 2.0,
  "id": "main_charts",
  "type": "widget",
  "name": "Zabbix: host charts",
  "namespace": "MainCharts",
  "version": "0.2.0",
  "author": "nicola",
  "description": "Dashboard widget: time-series charts for host metrics using Chart.js. Configure one or more series (item names), period, and chart style.",
  "widget": {
    "size": {
      "width": 48,
      "height": 12
    },
    "js_class": "CWidgetMainCharts"
  },
  "actions": {
    "widget.main_charts.lookup": {
      "class": "ItemLookup",
      "layout": "layout.json"
    },
    "widget.main_charts.history": {
      "class": "ChartHistory",
      "layout": "layout.json"
    },
    "widget.main_charts.view": {
      "class": "WidgetView"
    }
  },
  "assets": {
    "css": ["widget.config.css", "widget.default.css", "widget.edit.css"],
    "js": [
      "chart.umd.min.js",
      "chartjs-adapter-date-fns.bundle.min.js",
      "class.widget.js"
    ]
  }
}
