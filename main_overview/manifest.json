{
  "manifest_version": 2.0,
  "id": "main_overview",
  "type": "widget",
  "name": "Zabbix: host overview",
  "namespace": "MainOverview",
  "version": "0.5.5",
  "author": "nicola",
  "description": "Dashboard widget: CPU, memory, load, swap, interfaces, disks, and partitions, badges, sparklines, and per-host overrides. Intended for typical Zabbix agent templates.",
  "widget": {
    "size": {
      "width": 38,
      "height": 4
    },
    "js_class": "CWidgetMainOverview"
  },
  "actions": {
    "widget.main_overview.lookup": {
      "class": "MetricLookup",
      "layout": "layout.json"
    },
    "widget.main_overview.sparkline": {
      "class": "SparklineHistory",
      "layout": "layout.json"
    },
    "widget.main_overview.view": {
      "class": "WidgetView"
    }
  },
  "assets": {
    "css": [
      "widget.edit.css",
      "widget.config.css",
      "widget.toolbar.css",
      "widget.default.css",
      "widget.sparkline.css"
    ],
    "js": ["class.sparkline.js", "class.widget.js"]
  }
}
