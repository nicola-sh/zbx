{
  "manifest_version": 2.0,
  "id": "main_overview",
  "type": "widget",
  "name": "Zabbix: обзор узла",
  "namespace": "MainOverview",
  "version": "0.5.4",
  "author": "nicola",
  "description": "Виджет дашборда: сводка по CPU, памяти, нагрузке, свопу, интерфейсам, дискам и разделам, значки, спарклайны и переопределения по узлам. Рассчитан на типовые шаблоны Zabbix Agent.",
  "widget": {
    "size": {
      "width": 38,
      "height": 4
    },
    "js_class": "CWidgetMainOverview"
  },
  "actions": {
    "widget.main_overview.lookup": {
      "class": "MetricLookup",
      "layout": "layout.json"
    },
    "widget.main_overview.sparkline": {
      "class": "SparklineHistory",
      "layout": "layout.json"
    },
    "widget.main_overview.view": {
      "class": "WidgetView"
    }
  },
  "assets": {
    "css": [
      "widget.edit.css",
      "widget.config.css",
      "widget.toolbar.css",
      "widget.default.css",
      "widget.sparkline.css"
    ],
    "js": ["class.sparkline.js", "class.widget.js"]
  }
}
