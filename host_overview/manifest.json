{
  "manifest_version": 2.0,
  "id": "host_overview",
  "type": "widget",
  "name": "Host overview",
  "namespace": "HostOverview",
  "version": "1.3",
  "author": "ObviousAIChicken",
  "description": "Displays a configurable summary of a Linux or Windows host using the default host template. (github.com/obviousaichicken/zabbix_widgets)",
  "widget": {
    "size": {
      "width": 38,
      "height": 4
    },
    "js_class": "CWidgetHostOverview"
  },
  "actions": {
    "widget.host_overview.lookup": {
      "class": "MetricLookup",
      "layout": "layout.json"
    },
    "widget.host_overview.view": {
      "class": "WidgetView"
    }
  },
  "assets": {
    "css": ["widget.css"],
    "js": ["class.sparkline.js", "class.widget.js"]
  }
}
